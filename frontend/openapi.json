  "info": {
    "description": "Compliance readiness analysis backend for CompAud.",
    "title": "CompAud Backend",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get backend health",
        "tags": [
          "system"
        ]
      }
    },
    "/ps3/analyze": {
      "post": {
        "operationId": "analyzePs3",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PS3ReportResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Run the full PS3 compliance analysis (collect -> link -> evaluate -> report)",
        "tags": [
          "ps3"
        ]
      }
    },
    "/ps3/analyze/stream": {
      "get": {
        "operationId": "streamPs3Analyze",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Stream PS3 compliance analysis progress (SSE)",
        "tags": [
          "ps3"
        ]
      }
    },
    "/ps3/report.pdf": {
      "get": {
        "operationId": "getPs3ReportPdf",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              },
              "application/pdf": {}
            },
            "description": "PDF report"
          }
        },
        "summary": "Download the PS3 audit report as PDF",
        "tags": [
          "ps3"
        ]
      }
    },
    "/ps3/requirements": {
      "get": {
        "operationId": "getPs3Requirements",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequirementCatalogResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get parsed policy requirements",
        "tags": [
          "ps3"
        ]
      }
    },
    "/ps3/requirements/{requirement_id}": {
      "get": {
        "operationId": "getPs3Requirement",
        "parameters": [
          {
            "in": "path",
            "name": "requirement_id",
            "required": true,
            "schema": {
              "title": "Requirement Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequirementCatalogResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get a single parsed requirement by minted id",
        "tags": [
          "ps3"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "Backend health and runtime configuration.",
      "name": "system"
    },
    {
      "description": "Automated compliance evidence collection & audit (PS3).",
      "name": "ps3"
    }
  ]
}
